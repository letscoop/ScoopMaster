{
  "version": "5.37",
  "description": "Victoria HDD/SSD is the best free program for diagnosing, researching, testing, and minor repairs of hard drives, SSDs, memory cards, and any other storage devices in the Windows operating system.",
  "homepage": "https://hdd.by/victoria/",
  "license": "Freeware",
  "url": "https://hdd.by/Victoria/Victoria537.zip",
  "hash": "sha256:a66b7869d59bbf90b5994332bac57bcbc0b377cee9f0c59c078795ea7b4c99d1",
  "installer": {
    "script": [
      "$archiveDir = Join-Path $dir \"Victoria$($version -replace '\\.', '')\"",
      "if (Test-Path $archiveDir) {",
      "  Get-ChildItem -Path $archiveDir -Force | Move-Item -Destination $dir -Force",
      "  Remove-Item $archiveDir -Force -Recurse",
      "}"
    ]
  },
  "bin": "Victoria.exe",
  "shortcuts": [
    [
      "Victoria.exe",
      "Victoria HDD SSD"
    ]
  ],
  "checkver": {
    "script": [
      "$resp = Invoke-WebRequest -Uri 'https://hdd.by/victoria/'",
      "$versions = @($resp.Links | ForEach-Object {",
      "  if ($_.href -match 'Victoria(?<digits>\\d+)\\.zip') { [int]$matches.digits }",
      "}) | Sort-Object -Descending",
      "if ($versions.Count -gt 0) {",
      "  $latest = [string]$versions[0]",
      "  if ($latest.Length -gt 1) {",
      "    '{0}.{1}' -f $latest.Substring(0, 1), $latest.Substring(1)",
      "  } else {",
      "    $latest",
      "  }",
      "}"
    ]
  },
  "autoupdate": {
    "url": "https://hdd.by/Victoria/Victoria$cleanVersion.zip"
  }
}
