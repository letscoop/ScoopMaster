{
    "version": "1.2.20.2305",
    "description": "A cross-platform local music player for Windows, Linux, Android, iOS, and macOS.",
    "homepage": "https://karing.app/",
    "license": {
        "identifier": " GNU GENERAL PUBLIC LICENSE",
        "url": "https://github.com/wesley666/LynMusic#License-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/KaringX/karing/releases/download/v1.2.20.2305/karing_1.2.20.2305_windows_x64.exe",
            "hash": "69dc4eb29a4642cdffaf2e7b3dd826443810554568f536f5602d492c1820fb16"
        }
    },
    "innosetup": true,
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\LynMusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\LynMusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "LynMusic.exe",
    "shortcuts": [
        [
            "LynMusic.exe",
            "LynMusic"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/wesley666/LynMusic/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/LynMusic-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wesley666/LynMusic/releases/download/v$version/LynMusic-$version.msi"
            }
        }
    }
}
