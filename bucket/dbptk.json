    "url": "https://github.com/keeps/dbptk-desktop/releases/download/v4.1.0/dbptk-desktop-4.1.0.exe#/dl.7z",
    "hash": "sha512:0b95948659384a69528e09460f620a6b9ccc0958fb2d5e435af9fd8397677427d226e167cd18b3ff5c45b79fbbc8aed40afa20b67fe6790c1d318211e8efa07e",
    "architecture": {
        "64bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "32bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-32.7z\" \"$dir\""
