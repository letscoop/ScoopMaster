{
    "version": "3.1.6.0",
    "description": "123云盘是一款空间大、不限速、专注大文件传输分发的云存储服务产品。",
    "homepage": "https://www.123pan.com/",
    "license": "Proprietary",
    "url": "https://app.123957.com/pc-pro/windows/316/123pan_3.1.6.exe#/dl.7z",
    "hash": "c36d4160e6272bda658782779d11149300c1387e06120099d4ae5289d33e50db",
    "shortcuts": [
        [
            "123pan.exe",
            "123云盘"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "Require-Admin",
            "Write-Host \"`nPersisting $env:APPDATA\\123pan ... \" -NoNewline",
            "New-PersistDirectory \"$env:APPDATA\\123pan\" \"$persist_dir\\AppData\" -Migrate",
            "Expand-7zipArchive \"$dir\\app.7z\" \"$dir\" -Removal",
            "Remove-Item \"$dir\\`$*\" -Recurse -Force",
            "Write-Host \"`nRegistering 123pan installation ... \" -NoNewline",
            "Set-RegValue -Path \"HKLM:\\SOFTWARE\\Wow6432Node\\123pan\" -Name \"InstallPath\" -Value \"$dir\" -Type REG_SZ",
            "",
            "Write-Host \"`nConfiguring 123SyncCloud Service ... \" -ForegroundColor Yellow",
            "$svcDir = \"$env:ProgramData\\123SyncCloud\\service\"",
            "$svcPath = \"$svcDir\\MaintenanceService.exe\"",
            "# 如果系统目录中没有服务文件，则尝试从 Scoop 解压目录中寻找并复制",
            "if (-not (Test-Path $svcPath)) {",
            "    $found = Get-ChildItem \"$dir\" -Filter \"MaintenanceService.exe\" -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1",
            "    if ($found) {",
            "        New-Item -ItemType Directory -Force $svcDir | Out-Null",
            "        Copy-Item $found.FullName $svcPath -Force",
            "        Write-Host \"Copied MaintenanceService.exe to ProgramData.\" -ForegroundColor DarkGray",
            "    }",
            "}",
            "# 如果文件就绪，则使用原生命令注册服务，即时生效",
            "if (Test-Path $svcPath) {",
            "    $svcName = \"123SyncCloud Maintenance Service\"",
            "    if (-not (Get-Service $svcName -ErrorAction SilentlyContinue)) {",
            "        # 使用 New-Service 正式向系统注册服务，无需重启即可被系统识别",
            "        New-Service -Name $svcName -BinaryPathName \"`\"$svcPath`\"\" -DisplayName \"123SyncCloud Maintenance Service\" -StartupType Automatic | Out-Null",
            "    }",
            "    # 补充写入描述注册表（New-Service 在部分旧版 PS 中不支持直接写 Description）",
            "    $regPath = \"HKLM:\\SYSTEM\\CurrentControlSet\\Services\\$svcName\"",
            "    Set-ItemProperty -Path $regPath -Name \"Description\" -Value \"123云盘用于核心业务所需的服务。为保证123云盘正常运行，请勿停止本服务\" -Type String -ErrorAction SilentlyContinue",
            "    ",
            "    # 立即启动服务",
            "    Start-Service $svcName -ErrorAction SilentlyContinue",
            "    Write-Host \"Service registered and started successfully.\" -ForegroundColor Green",
            "} else {",
            "    Write-Host \"Warning: MaintenanceService.exe not found! Service cannot be registered.\" -ForegroundColor Red",
            "}"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Require-Admin",
        "Stop-App",
        "Stop-Service \"123SyncCloud Maintenance Service\" -ErrorAction SilentlyContinue",
        "# 使用 sc 命令正式卸载服务，而不仅是删注册表",
        "& sc.exe delete \"123SyncCloud Maintenance Service\" | Out-Null"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "$localPaths = @(",
        "    \"$env:LOCALAPPDATA\\123pan-updater\"",
        "    \"$env:APPDATA\\123pan\"",
        "    \"$env:ProgramData\\123SyncCloud\"",
        ")",
        "$sid = [System.Security.Principal.WindowsIdentity]::GetCurrent().User.Value",
        "$regPaths = @(",
        "    \"HKLM\\SOFTWARE\\Classes\\*\\shell\\123pan\"",
        "    \"HKLM\\SOFTWARE\\Classes\\Directory\\shell\\123pan\"",
        "    \"HKLM\\SOFTWARE\\Wow6432Node\\123pan\"",
        "    \"HKLM\\SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\123pan\"",
        "    \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\123SyncCloud Maintenance Service\"",
        "    \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\123SyncCloud Upgrade Service\"",
        "    \"HKU\\$sid\\SOFTWARE\\123pan\"",
        "    \"HKU\\$sid\\SOFTWARE\\Classes\\CLSID\\{D5BE1ADA-C1D3-4DF9-9317-95D61C28F6FA}\\DefaultIcon\"",
        "    \"HKU\\$sid\\SOFTWARE\\Classes\\CLSID\\{D5BE1ADA-C1D3-4DF9-9317-95D61C28F6FA}\\Shell\"",
        "    \"HKU\\$sid\\SOFTWARE\\Classes\\pan123\\shell\\open\"",
        ")",
        "$regValues = @(",
        "    \"HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Environment|123pan\"",
        "    \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\SharedAccess\\Parameters\\FirewallPolicy\\FirewallRules|TCP Query User{5A335076-A09D-42BF-8A77-C7C3756B0DC5}$dir\\\\123pan.exe\"",
        "    \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\SharedAccess\\Parameters\\FirewallPolicy\\FirewallRules|UDP Query User{6C459033-4495-4755-8F71-F95B628D7FAF}$dir\\\\123pan.exe\"",
        "    \"HKU\\$sid\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\UserAssist\\{CEBFF5CD-ACE2-4F4F-9178-9926F41749EA}\\Count|P:\\\\Hfref\\\\JvaGrfg\\\\NccQngn\\\\Ybpny\\\\123cna\\\\123cna.rkr\"",
        "    \"HKU\\$sid\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Compatibility Assistant\\Store|$dir\\\\123pan.exe\"",
        ")",
        "Remove-AppData -LocalPaths $localPaths -RegistryPaths $regPaths -RegistryValues $regValues"
    ],
    "checkver": {
        "script": [
            "Import-Module \"$pwd\\bin\\WinGet.psm1\"",
            "$Manifest = Get-WinGetManifest -Id '123.123pan'",
            "$version  = $Manifest.PackageVersion",
            "$url      = $Manifest.Installers.InstallerUrl",
            "return \"$version=====$url\""
        ],
        "regex": "(.*)=====(?<url>.*)"
    },
    "autoupdate": {
        "url": "$matchUrl#/dl.7z"
    },
    "notes": [
        "You'll see a UAC prompt during installation. Don't worry, it will be completely removed when you uninstall.",
        "User data is persisted in \"$persist_dir\"."
    ]
}
